# =============================================
# Zambeel Supplier Portal — Environment Variables
# Copy this file to .env.local and fill in your values.
# =============================================

# Supabase — required for all data operations
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Service Role Key — used by server-side API routes only.
# NEVER expose this in the browser / NEXT_PUBLIC_* variables.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Join page invite code — protects /join from public registrations.
# Change this to a secret value before going live.
NEXT_PUBLIC_JOIN_INVITE_CODE=ZBL-TEAM-2025
